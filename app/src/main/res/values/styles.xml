        <item name="colorPrimary">#9d4edd</item>
        <item name="colorPrimaryVariant">#7f00ff</item>
        <item name="colorOnPrimary">#ffffff</item>
        <!-- Secondary brand color. -->
        <item name="colorSecondary">#00f2fe</item>
